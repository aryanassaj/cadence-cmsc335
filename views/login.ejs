<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — Cadence</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <nav>
    <a class="nav-brand" href="/">Cadence</a>
    <div class="nav-links">
      <a href="/auth/register">No account? Register</a>
    </div>
  </nav>

  <div class="container" style="max-width:440px;padding-top:3rem;">
    <h2>Welcome back</h2>
    <p class="text-muted" style="margin-bottom:1.5rem;">Log in to continue tracking your cognitive health.</p>

    <% if (error) { %>
      <div class="error-msg"><%= error %></div>
    <% } %>

    <div class="card">
      <form method="POST" action="/auth/login">
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" placeholder="you@example.com" required>
        </div>
        <div class="form-group">
          <label>Password</label>
          <input type="password" name="password" required>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;margin-top:0.5rem;">Log In</button>
      </form>
    </div>
  </div>
</body>
</html>
