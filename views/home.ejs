<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>

<script>
/* ──────────────────────────────────────────────────────────────
   LENIS SMOOTH SCROLL
────────────────────────────────────────────────────────────── */
const lenis = new Lenis({ lerp: 0.08, smoothWheel: true });
function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
requestAnimationFrame(raf);
gsap.registerPlugin(ScrollTrigger);
lenis.on("scroll", ScrollTrigger.update);
gsap.ticker.add((time) => lenis.raf(time * 1000));
gsap.ticker.lagSmoothing(0);

/* ──────────────────────────────────────────────────────────────
   NAV SCROLL EFFECT
────────────────────────────────────────────────────────────── */
const nav = document.getElementById("l-nav");
ScrollTrigger.create({
  start: "top -60px",
  onEnter:     () => nav.classList.add("scrolled"),
  onLeaveBack: () => nav.classList.remove("scrolled"),
});

/* ──────────────────────────────────────────────────────────────
   NEURAL CANVAS — HERO BACKGROUND
────────────────────────────────────────────────────────────── */
(function () {
  const canvas = document.getElementById("neural-canvas");
  const ctx    = canvas.getContext("2d");
  let W, H, particles;

  function resize() {
    W = canvas.width  = canvas.offsetWidth;
    H = canvas.height = canvas.offsetHeight;
    build();
  }

  function build() {
    const count = Math.floor((W * H) / 14000);
    particles = Array.from({ length: count }, () => ({
      x:  Math.random() * W,
      y:  Math.random() * H,
      vx: (Math.random() - 0.5) * 0.28,
      vy: (Math.random() - 0.5) * 0.28,
      r:  Math.random() * 1.6 + 0.6,
      pulse: Math.random() * Math.PI * 2,
    }));
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    const maxDist = 130;

    particles.forEach(p => {
      p.x += p.vx; p.y += p.vy;
      if (p.x < 0) p.x = W; if (p.x > W) p.x = 0;
      if (p.y < 0) p.y = H; if (p.y > H) p.y = 0;
      p.pulse += 0.012;
      const alpha = 0.22 + 0.14 * Math.sin(p.pulse);
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(99,102,241,${alpha})`;
      ctx.fill();
    });

    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const a = particles[i], b = particles[j];
        const dx = a.x - b.x, dy = a.y - b.y;
        const d  = Math.sqrt(dx * dx + dy * dy);
        if (d < maxDist) {
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b.x, b.y);
          ctx.strokeStyle = `rgba(99,102,241,${(1 - d / maxDist) * 0.11})`;
          ctx.lineWidth = 0.7;
          ctx.stroke();
        }
      }
    }
    requestAnimationFrame(draw);
  }

  window.addEventListener("resize", resize);
  resize();
  draw();
})();

/* ──────────────────────────────────────────────────────────────
   WAVEFORM CANVAS
────────────────────────────────────────────────────────────── */
(function () {
  const canvas = document.getElementById("waveform-canvas");
  const ctx    = canvas.getContext("2d");
  const BARS   = 40;
  let t = 0;

  function resize() {
    canvas.width  = canvas.offsetWidth  * devicePixelRatio;
    canvas.height = canvas.offsetHeight * devicePixelRatio;
    ctx.scale(devicePixelRatio, devicePixelRatio);
  }

  function draw() {
    const W = canvas.offsetWidth, H = canvas.offsetHeight;
    ctx.clearRect(0, 0, W, H);
    const barW = (W / 2 - 20) / BARS * 0.62;
    const gap  = (W / 2 - 20) / BARS * 0.38;
    const mid  = H / 2;

    for (let i = 0; i < BARS; i++) {
      const xL = 10 + i * (barW + gap);
      const xR = W / 2 + 10 + i * (barW + gap);
      const hH = (Math.sin(t + i * 0.42) * 0.38 + 0.14) * mid * 0.9;
      const hD = (Math.sin(t * 0.55 + i * 0.8 + Math.sin(i * 1.4) * 1.1) * 0.16 + 0.06) * mid * 0.9;

      // healthy (left half)
      ctx.fillStyle = "rgba(59,130,246,0.75)";
      ctx.beginPath();
      ctx.roundRect(xL, mid - hH, barW, hH, 2);
      ctx.fill();
      ctx.fillStyle = "rgba(59,130,246,0.2)";
      ctx.beginPath();
      ctx.roundRect(xL, mid, barW, hH * 0.45, 2);
      ctx.fill();

      // declining (right half)
      ctx.fillStyle = "rgba(139,92,246,0.6)";
      ctx.beginPath();
      ctx.roundRect(xR, mid - hD, barW, hD, 2);
      ctx.fill();
      ctx.fillStyle = "rgba(139,92,246,0.18)";
      ctx.beginPath();
      ctx.roundRect(xR, mid, barW, hD * 0.45, 2);
      ctx.fill();
    }

    // divider
    ctx.beginPath();
    ctx.moveTo(W / 2, 12);
    ctx.lineTo(W / 2, H - 12);
    ctx.strokeStyle = "rgba(255,255,255,0.06)";
    ctx.lineWidth = 1;
    ctx.stroke();

    ctx.font = "500 10px Inter, sans-serif";
    ctx.fillStyle = "rgba(59,130,246,0.55)";
    ctx.fillText("Healthy rhythm", 12, H - 10);
    ctx.fillStyle = "rgba(139,92,246,0.55)";
    ctx.fillText("Irregular pattern", W / 2 + 12, H - 10);

    t += 0.018;
    requestAnimationFrame(draw);
  }

  window.addEventListener("resize", resize);
  resize();
  draw();
})();

/* ──────────────────────────────────────────────────────────────
   BRAIN ZOOM — VIDEO FRAME SCRUBBER
────────────────────────────────────────────────────────────── */
(function () {
  const canvas = document.getElementById("brain-zoom-canvas");
  if (!canvas) return;
  const ctx = canvas.getContext("2d");

  const TOTAL  = 192;
  const frames = new Array(TOTAL);
  let loaded   = 0;
  let curIdx   = 0;
  let allReady = false;

  const LOBES = [
    { name: "Frontal Lobe",  color: "#3b82f6" },
    { name: "Parietal Lobe", color: "#8b5cf6" },
    { name: "Temporal Lobe", color: "#06b6d4" },
    { name: "Cerebellum",    color: "#10b981" },
  ];

  /* ── Canvas resize — redraws current frame to fill ── */
  function resize() {
    canvas.width  = canvas.offsetWidth  * devicePixelRatio;
    canvas.height = canvas.offsetHeight * devicePixelRatio;
    paint(frames[curIdx]);
  }
  window.addEventListener("resize", resize);
  resize();

  /* ── Cover-fill draw ── */
  function paint(img) {
    if (!img || !img.complete || !img.naturalWidth) return;
    const W = canvas.width, H = canvas.height;
    const iw = img.naturalWidth, ih = img.naturalHeight;
    const canAr = W / H, imgAr = iw / ih;
    let sx, sy, sw, sh;
    if (imgAr > canAr) { sh = ih; sw = sh * canAr; sx = (iw - sw) / 2; sy = 0; }
    else               { sw = iw; sh = sw / canAr; sx = 0; sy = (ih - sh) / 2; }
    ctx.drawImage(img, sx, sy, sw, sh, 0, 0, W, H);
  }

  /* ── Loading placeholder ── */
  function drawPlaceholder() {
    const W = canvas.width, H = canvas.height;
    ctx.fillStyle = "#020406";
    ctx.fillRect(0, 0, W, H);
    const pct = Math.round((loaded / TOTAL) * 100);
    ctx.fillStyle = "rgba(255,255,255,0.12)";
    ctx.fillRect(W * 0.35, H * 0.5 - 1, W * 0.3 * (loaded / TOTAL), 2);
    ctx.fillStyle = "rgba(255,255,255,0.18)";
    ctx.font      = `${11 * devicePixelRatio}px Inter, sans-serif`;
    ctx.textAlign = "center";
    ctx.fillText(`${pct}%`, W * 0.5, H * 0.5 + 18 * devicePixelRatio);
    ctx.textAlign = "left";
  }

  /* ── Preload all 192 frames ── */
  drawPlaceholder();
  for (let i = 0; i < TOTAL; i++) {
    const img = new Image();
    img.onload = () => {
      loaded++;
      if (!allReady) drawPlaceholder();
      if (loaded === TOTAL) {
        allReady = true;
        paint(frames[0]);
      }
    };
    img.src = `/frames/frame${String(i + 1).padStart(4, "0")}.jpg`;
    frames[i] = img;
  }

  /* ── ScrollTrigger: scrub frames ── */
  const panels      = [0,1,2,3].map(i => document.getElementById("bz-"+i));
  const dots        = document.querySelectorAll(".l-bz-dot");
  const regionLabel = document.getElementById("bz-region-label");
  const regionName  = document.getElementById("bz-region-name");

  /*
   * Panel thresholds calibrated to the actual video content:
   *   0–16%   : Frontal Lobe  (blue glow, front of brain)
   *   16–50%  : Parietal Lobe (full purple brain)
   *   50–68%  : Temporal Lobe (cyan lightning, side/base)
   *   68–100% : Cerebellum    (teal → green, back base)
   */
  const BOUNDS = [0.16, 0.50, 0.68];
  const H      = 0.025; // 2.5% dead-zone so Lenis inertia can't oscillate at a boundary
  let lastReg  = -1;    // -1 = uninitialised; forces first activateRegion call to execute

  function activateRegion(reg) {
    if (reg === lastReg) return;
    lastReg = reg;
    panels.forEach((el, i) => el.classList.toggle("active", i === reg));
    dots.forEach((d, i)    => d.classList.toggle("active",  i === reg));
    regionName.textContent = LOBES[reg].name;
    regionName.style.color = LOBES[reg].color;
    regionLabel.classList.add("visible");
  }

  /* Determine region from raw progress — used on first entry and re-entry */
  function regionAt(p) {
    if (p < BOUNDS[0]) return 0;
    if (p < BOUNDS[1]) return 1;
    if (p < BOUNDS[2]) return 2;
    return 3;
  }

  ScrollTrigger.create({
    trigger: ".l-brainzoom-trigger",
    start:   "top top",
    end:     "bottom bottom",
    /* Snap to correct region instantly on enter/leave — no hysteresis needed here */
    onEnter(self)    { activateRegion(regionAt(self.progress)); },
    onLeaveBack()    { lastReg = -1; activateRegion(0); },
    onUpdate(self) {
      /* Frame scrub */
      if (allReady) {
        const idx = Math.min(TOTAL - 1, Math.floor(self.progress * TOTAL));
        if (idx !== curIdx) { curIdx = idx; paint(frames[curIdx]); }
      }

      /* Panel switching with hysteresis — one step at a time */
      const p = self.progress;
      let reg = lastReg < 0 ? regionAt(p) : lastReg;
      if (reg < 3 && p >= BOUNDS[reg]     + H) reg++;
      if (reg > 0 && p <  BOUNDS[reg - 1] - H) reg--;
      activateRegion(reg);
    },
  });
})();

/* ──────────────────────────────────────────────────────────────
   HERO ENTRANCE
────────────────────────────────────────────────────────────── */
gsap.timeline({ defaults: { ease: "power3.out" } })
  .to("#hero-eyebrow", { opacity: 1, duration: 0.9, delay: 0.3 })
  .to(".l-line-inner", { y: "0%", duration: 1.1, stagger: 0.14 }, "-=0.5")
  .to(["#hero-desc", "#hero-actions"], { opacity: 1, y: 0, duration: 0.9, stagger: 0.12 }, "-=0.4")
  .to("#hero-scroll", { opacity: 1, duration: 0.7 }, "-=0.3");

/* ──────────────────────────────────────────────────────────────
   SCROLL REVEAL
────────────────────────────────────────────────────────────── */
document.querySelectorAll("[data-reveal]").forEach(el => {
  ScrollTrigger.create({
    trigger: el,
    start: "top 88%",
    onEnter() { el.classList.add("visible"); },
  });
});

/* ──────────────────────────────────────────────────────────────
   PIPELINE SCROLL ANIMATION
────────────────────────────────────────────────────────────── */
(function () {
  const nodes     = document.querySelectorAll(".l-pipe-node");
  const connectors= document.querySelectorAll(".l-pipe-connector");
  const litClasses= ["lit","lit-cyan","lit-purple","lit-green","lit-blue2"];
  let lastStep    = -1;

  ScrollTrigger.create({
    trigger: ".l-pipeline-trigger",
    start: "top top",
    end: "bottom bottom",
    onUpdate(self) {
      // 5 nodes, each occupies 20% of scroll range
      const step = Math.min(nodes.length - 1, Math.floor(self.progress * nodes.length));
      if (step === lastStep) return;
      lastStep = step;
      nodes.forEach((n, i) => {
        n.classList.remove(...litClasses);
        if (i <= step) n.classList.add(litClasses[i]);
      });
      connectors.forEach((c, i) => {
        c.classList.toggle("lit", i < step);
      });
    },
  });
})();

/* ──────────────────────────────────────────────────────────────
   CHAPTER CANVAS 01 — DATASET SCATTER (healthy vs declining)
────────────────────────────────────────────────────────────── */
(function () {
  const canvas = document.getElementById("ch-dataset-canvas");
  if (!canvas) return;
  const ctx = canvas.getContext("2d");
  let t = 0;

  function resize() {
    canvas.width  = canvas.offsetWidth  * devicePixelRatio;
    canvas.height = canvas.offsetHeight * devicePixelRatio;
    ctx.scale(devicePixelRatio, devicePixelRatio);
  }

  // Generate stable dot positions
  function seeded(seed) {
    let s = seed;
    return () => { s = (s * 16807 + 0) % 2147483647; return (s - 1) / 2147483646; };
  }
  const rand = seeded(42);

  const dots = Array.from({ length: 205 }, (_, i) => {
    const healthy = i < 120;
    const cx = healthy ? 0.35 : 0.67;
    const cy = healthy ? 0.42 : 0.56;
    return {
      x: cx + (rand() - 0.5) * 0.34,
      y: cy + (rand() - 0.5) * 0.38,
      healthy,
      phase: rand() * Math.PI * 2,
      r: rand() * 1.8 + 2,
    };
  });

  function draw() {
    const W = canvas.offsetWidth, H = canvas.offsetHeight;
    ctx.clearRect(0, 0, W, H);

    // axis labels
    ctx.font = `500 10px Inter, sans-serif`;
    ctx.fillStyle = "rgba(255,255,255,0.18)";
    ctx.fillText("IKI mean →", W * 0.06, H * 0.95);
    ctx.save(); ctx.translate(W * 0.04, H * 0.5);
    ctx.rotate(-Math.PI / 2);
    ctx.fillText("IKI std dev →", 0, 0);
    ctx.restore();

    dots.forEach(d => {
      d.phase += 0.008;
      const jitter = Math.sin(d.phase) * 0.004;
      const x = (d.x + jitter) * W;
      const y = (d.y + jitter) * H;
      const alpha = d.healthy ? 0.65 + 0.2 * Math.sin(d.phase * 0.7) : 0.55 + 0.18 * Math.sin(d.phase * 0.5);
      ctx.beginPath();
      ctx.arc(x, y, d.r, 0, Math.PI * 2);
      ctx.fillStyle = d.healthy
        ? `rgba(59,130,246,${alpha})`
        : `rgba(139,92,246,${alpha})`;
      ctx.fill();
    });

    // legend
    ctx.beginPath(); ctx.arc(W * 0.12, H * 0.08, 4, 0, Math.PI * 2);
    ctx.fillStyle = "rgba(59,130,246,0.8)"; ctx.fill();
    ctx.fillStyle = "rgba(255,255,255,0.45)"; ctx.font = "500 10px Inter, sans-serif";
    ctx.fillText("Healthy (120)", W * 0.16, H * 0.08 + 4);

    ctx.beginPath(); ctx.arc(W * 0.5, H * 0.08, 4, 0, Math.PI * 2);
    ctx.fillStyle = "rgba(139,92,246,0.8)"; ctx.fill();
    ctx.fillStyle = "rgba(255,255,255,0.45)";
    ctx.fillText("Parkinson's (85)", W * 0.54, H * 0.08 + 4);

    t += 0.01;
    requestAnimationFrame(draw);
  }

  window.addEventListener("resize", resize);
  resize();
  draw();
})();

/* ──────────────────────────────────────────────────────────────
   CHAPTER CANVAS 02 — FEATURE BAR CHART (animated live bars)
────────────────────────────────────────────────────────────── */
(function () {
  const canvas = document.getElementById("ch-features-canvas");
  if (!canvas) return;
  const ctx = canvas.getContext("2d");

  const features = [
    { label: "Mean IKI",     color: "#3b82f6", base: 0.62, phase: 0.0 },
    { label: "IKI Std Dev",  color: "#06b6d4", base: 0.81, phase: 0.8 },
    { label: "Hold Time",    color: "#8b5cf6", base: 0.44, phase: 1.6 },
    { label: "Flight Time",  color: "#10b981", base: 0.58, phase: 2.4 },
    { label: "WPM",          color: "#3b82f6", base: 0.35, phase: 3.2 },
    { label: "Backspace %",  color: "#f59e0b", base: 0.27, phase: 4.0 },
    { label: "Pause Freq",   color: "#06b6d4", base: 0.70, phase: 4.8 },
  ];

  function resize() {
    canvas.width  = canvas.offsetWidth  * devicePixelRatio;
    canvas.height = canvas.offsetHeight * devicePixelRatio;
    ctx.scale(devicePixelRatio, devicePixelRatio);
  }

  let t = 0;
  function draw() {
    const W = canvas.offsetWidth, H = canvas.offsetHeight;
    ctx.clearRect(0, 0, W, H);

    const padL = 92, padR = 20, padT = 24, padB = 16;
    const chartW = W - padL - padR;
    const barH   = (H - padT - padB) / features.length;
    const barGap = barH * 0.28;
    const barNet = barH - barGap;

    features.forEach((f, i) => {
      const val = f.base + Math.sin(t + f.phase) * 0.07;
      const bw  = val * chartW;
      const y   = padT + i * barH + barGap / 2;

      // track
      ctx.fillStyle = "rgba(255,255,255,0.04)";
      ctx.beginPath(); ctx.roundRect(padL, y, chartW, barNet, 3); ctx.fill();

      // bar
      const r = parseInt(f.color.slice(1,3),16), g = parseInt(f.color.slice(3,5),16), b2 = parseInt(f.color.slice(5,7),16);
      const grad = ctx.createLinearGradient(padL, 0, padL + bw, 0);
      grad.addColorStop(0, `rgba(${r},${g},${b2},0.85)`);
      grad.addColorStop(1, `rgba(${r},${g},${b2},0.35)`);
      ctx.fillStyle = grad;
      ctx.beginPath(); ctx.roundRect(padL, y, bw, barNet, 3); ctx.fill();

      // label
      ctx.font = "500 10.5px Inter, sans-serif";
      ctx.fillStyle = "rgba(255,255,255,0.45)";
      ctx.textAlign = "right";
      ctx.fillText(f.label, padL - 8, y + barNet / 2 + 4);

      // value
      ctx.font = "600 10px Space Mono, monospace";
      ctx.fillStyle = f.color;
      ctx.textAlign = "left";
      ctx.fillText((val * 100).toFixed(0), padL + bw + 6, y + barNet / 2 + 4);
    });

    ctx.textAlign = "left";
    t += 0.014;
    requestAnimationFrame(draw);
  }

  window.addEventListener("resize", resize);
  resize();
  draw();
})();

/* ──────────────────────────────────────────────────────────────
   CHAPTER CANVAS 03 — SIGMOID MODEL CURVE
────────────────────────────────────────────────────────────── */
(function () {
  const canvas = document.getElementById("ch-model-canvas");
  if (!canvas) return;
  const ctx = canvas.getContext("2d");
  let t = 0;

  function resize() {
    canvas.width  = canvas.offsetWidth  * devicePixelRatio;
    canvas.height = canvas.offsetHeight * devicePixelRatio;
    ctx.scale(devicePixelRatio, devicePixelRatio);
  }

  function sigmoid(x) { return 1 / (1 + Math.exp(-x)); }

  function draw() {
    const W = canvas.offsetWidth, H = canvas.offsetHeight;
    ctx.clearRect(0, 0, W, H);

    const padL = 48, padR = 28, padT = 28, padB = 44;
    const cW = W - padL - padR, cH = H - padT - padB;

    // Grid lines
    [0, 0.33, 0.55, 1].forEach(v => {
      const y = padT + (1 - v) * cH;
      ctx.beginPath(); ctx.moveTo(padL, y); ctx.lineTo(padL + cW, y);
      ctx.strokeStyle = v === 0 ? "rgba(255,255,255,0.08)" : "rgba(255,255,255,0.05)";
      ctx.lineWidth = 0.8; ctx.setLineDash([4, 4]); ctx.stroke();
      ctx.setLineDash([]);
      if (v > 0 && v < 1) {
        ctx.font = "500 9px Space Mono, monospace";
        ctx.fillStyle = "rgba(255,255,255,0.25)";
        ctx.fillText(v.toFixed(2), 4, y + 4);
      }
    });

    // Axis
    ctx.beginPath(); ctx.moveTo(padL, padT); ctx.lineTo(padL, padT + cH); ctx.lineTo(padL + cW, padT + cH);
    ctx.strokeStyle = "rgba(255,255,255,0.12)"; ctx.lineWidth = 1; ctx.setLineDash([]); ctx.stroke();

    // Sigmoid curve (animated scan position)
    const scanX = (Math.sin(t * 0.4) * 0.5 + 0.5) * cW;

    ctx.beginPath();
    for (let px = 0; px <= cW; px++) {
      const z   = (px / cW) * 10 - 5;
      const val = sigmoid(z);
      const y   = padT + (1 - val) * cH;
      px === 0 ? ctx.moveTo(padL + px, y) : ctx.lineTo(padL + px, y);
    }
    const grad = ctx.createLinearGradient(padL, 0, padL + cW, 0);
    grad.addColorStop(0,   "rgba(59,130,246,0.9)");
    grad.addColorStop(0.5, "rgba(99,102,241,0.9)");
    grad.addColorStop(1,   "rgba(139,92,246,0.9)");
    ctx.strokeStyle = grad; ctx.lineWidth = 2.5; ctx.stroke();

    // Area under curve
    ctx.beginPath();
    ctx.moveTo(padL, padT + cH);
    for (let px = 0; px <= cW; px++) {
      const z   = (px / cW) * 10 - 5;
      const val = sigmoid(z);
      ctx.lineTo(padL + px, padT + (1 - val) * cH);
    }
    ctx.lineTo(padL + cW, padT + cH); ctx.closePath();
    const areaGrad = ctx.createLinearGradient(0, padT, 0, padT + cH);
    areaGrad.addColorStop(0, "rgba(99,102,241,0.14)");
    areaGrad.addColorStop(1, "rgba(99,102,241,0)");
    ctx.fillStyle = areaGrad; ctx.fill();

    // Threshold zones
    const thresholds = [{ v: 0.33, label: "Low", color: "#10b981" }, { v: 0.55, label: "Med", color: "#f59e0b" }];
    thresholds.forEach(({ v, label, color }) => {
      const y = padT + (1 - v) * cH;
      ctx.font = "600 9px Space Mono, monospace";
      ctx.fillStyle = color;
      ctx.fillText(label, padL + cW + 4, y + 4);
    });

    // Scan line (moving dot on curve)
    const scanZ   = (scanX / cW) * 10 - 5;
    const scanVal = sigmoid(scanZ);
    const scanY   = padT + (1 - scanVal) * cH;
    ctx.beginPath(); ctx.moveTo(padL + scanX, padT + cH); ctx.lineTo(padL + scanX, scanY);
    ctx.strokeStyle = "rgba(255,255,255,0.12)"; ctx.lineWidth = 1; ctx.stroke();
    ctx.beginPath(); ctx.arc(padL + scanX, scanY, 5, 0, Math.PI * 2);
    ctx.fillStyle = "#fff"; ctx.fill();
    ctx.font = "600 9px Space Mono, monospace";
    ctx.fillStyle = "rgba(255,255,255,0.55)";
    ctx.fillText(`score: ${scanVal.toFixed(2)}`, padL + scanX + 8, scanY - 6);

    // Axis labels
    ctx.font = "500 9px Inter, sans-serif"; ctx.fillStyle = "rgba(255,255,255,0.2)";
    ctx.textAlign = "center"; ctx.fillText("weighted feature score →", padL + cW / 2, padT + cH + 32);
    ctx.textAlign = "left";

    t += 0.016;
    requestAnimationFrame(draw);
  }

  window.addEventListener("resize", resize);
  resize();
  draw();
})();

/* ──────────────────────────────────────────────────────────────
   STATS COUNT-UP
────────────────────────────────────────────────────────────── */
document.querySelectorAll("[data-count]").forEach(el => {
  const target = parseInt(el.dataset.count, 10);
  ScrollTrigger.create({
    trigger: el,
    start: "top 85%",
    once: true,
    onEnter() {
      gsap.to({ val: 0 }, {
        val: target, duration: 2, ease: "power2.out",
        onUpdate() { el.textContent = Math.round(this.targets()[0].val); },
      });
    },
  });
});
</script>

